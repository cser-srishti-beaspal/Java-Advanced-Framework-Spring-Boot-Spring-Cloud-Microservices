spring.application.name=api-gateway

# ===============================
# BASIC CONFIG
# ===============================

server.port=8083

# ===============================
# EUREKA CLIENT CONFIG
# ===============================
eureka.client.service-url.defaultZone=http://localhost:8761/eureka
eureka.client.register-with-eureka=true
eureka.client.fetch-registry=true

# ===============================
# GATEWAY ROUTES (IMPORTANT)
# ===============================

# Route for PROJECT-SERVICE
spring.cloud.gateway.routes[0].id=project-service
spring.cloud.gateway.routes[0].uri=lb://project-service
spring.cloud.gateway.routes[0].predicates[0]=Path=/projects,/projects/**

# Route for STUDENT-SERVICE
spring.cloud.gateway.routes[1].id=student-service
spring.cloud.gateway.routes[1].uri=lb://student-service
spring.cloud.gateway.routes[1].predicates[0]=Path=/students/**

# ===============================
# ENABLE DISCOVERY LOCATOR (OPTIONAL BUT POWERFUL)
# ===============================
spring.cloud.gateway.discovery.locator.enabled=true
spring.cloud.gateway.discovery.locator.lower-case-service-id=true

# ===============================
# LOGGING (DEBUGGING)
# ===============================
logging.level.org.springframework.cloud.gateway=DEBUG